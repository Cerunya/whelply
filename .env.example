# ─────────────────────────────────────────────
# whelply.de — Environment Variables
# Kopiere diese Datei als .env.local (lokal) oder
# trage die Werte direkt in Coolify als Environment Variables ein
# ─────────────────────────────────────────────

# Datenbank (PostgreSQL auf Coolify)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://whelply:DEIN_PASSWORT@localhost:5432/whelply"

# Next.js
NEXTAUTH_URL="https://deine-domain.de"
NEXTAUTH_SECRET="generiere-mit: openssl rand -base64 32"

# MinIO (S3-kompatibler Speicher auf Coolify)
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="dein-minio-access-key"
MINIO_SECRET_KEY="dein-minio-secret-key"
MINIO_BUCKET="whelply-media"
MINIO_PUBLIC_URL="https://media.deine-domain.de"

# Stripe (für Boosts + Abos)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Produkt-IDs (nach Stripe-Setup eintragen)
STRIPE_PRICE_BOOST_1EUR="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PREMIUM_MONTHLY="price_..."

# Resend (E-Mail, kostenlos bis 3.000/Monat)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@whelply.de"

# Anthropic (KI-Features — Pro/Premium)
ANTHROPIC_API_KEY="sk-ant-..."

# App-URL
NEXT_PUBLIC_APP_URL="https://whelply.de"
